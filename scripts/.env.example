# Network selector — mirrors sol-base-bridge convention
NETWORK=devnet                                 # devnet | mainnet

# EVM (testnet target = Ethereum Sepolia, mainnet target = Base)
# Option A (preferred): BIP-39 mnemonic, derived at m/44'/60'/0'/0/0
MNEMONIC_KEY="word word word word word word word word word word word word"
WALLET_PASSPHRASE=                              # optional BIP-39 passphrase
# Option B (fallback): raw private key
# PRIVATE_KEY=0x...
BASE_RPC_URL=https://mainnet.base.org
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Solana
SOLANA_PAYER=~/.config/solana/id.json
SOLANA_RPC_URL=https://api.devnet.solana.com   # mainnet-beta when NETWORK=mainnet
