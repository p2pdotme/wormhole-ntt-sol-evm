# Used by `ntt` CLI on the Solana side
SOLANA_PAYER=~/.config/solana/id.json          # Path to keypair, has SOL on devnet
SOLANA_RPC=https://api.devnet.solana.com

# SPL token already deployed on devnet
# Devnet rehearsal: produced by ../solana/create-devnet-mint.sh
SPL_MINT=
# Mainnet token (do NOT use for devnet runs):
SPL_MINT_MAINNET=P2PXup1ZvMpCDkJn3PQxtBYgxeCSfH39SFeurGSmeta
SPL_DECIMALS=6

# Owners (can be the payer for testing; multisig for prod)
SOLANA_OWNER=REPLACE_WITH_PUBKEY
